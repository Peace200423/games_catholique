{
  "version": 2,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/leaderboard", "destination": "/api/leaderboard.js" },
    { "source": "/api/save-progress", "destination": "/api/save-progress.js" },
    { "source": "/api/load-progress", "destination": "/api/load-progress.js" },
    { "source": "/api/setup", "destination": "/api/setup.js" }
  ]
}
